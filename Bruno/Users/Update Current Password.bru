meta {
  name: Update Current Password
  type: http
  seq: 9
}

patch {
  url: {{URL}}api/v1/users/updateMyPassword
  body: json
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:json {
  {
    "passwordCurrent":{{password}},
    "password": {{password}},
    "passwordConfirm": {{password}}
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
