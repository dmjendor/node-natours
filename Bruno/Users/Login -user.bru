meta {
  name: Login -user
  type: http
  seq: 5
}

post {
  url: {{URL}}api/v1/users/login
  body: json
  auth: inherit
}

body:json {
  {
      "email": "test1@gmail.com",
      "password": {{[password]}}
  }
}

tests {
  const data = res.body;
  
  bru.setEnvVar("jwt", data.token);
}

settings {
  encodeUrl: true
  timeout: 0
}
