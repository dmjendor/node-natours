meta {
  name: New Review on Tour
  type: http
  seq: 9
}

post {
  url: {{URL}}api/v1/tours/69aedc03ce42360f1547ae13/reviews
  body: json
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:json {
  {
      "review": "Fun Time 7",
      "rating": 3.5
  }
}

tests {
  const data = res.body;
  
  bru.setEnvVar("jwt", data.token);
}

settings {
  encodeUrl: true
  timeout: 0
}
