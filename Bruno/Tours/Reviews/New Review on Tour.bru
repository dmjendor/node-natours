meta {
  name: New Review on Tour
  type: http
  seq: 9
}

post {
  url: {{URL}}api/v1/tours/5c88fa8cf4afda39709c2951/reviews
  body: json
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:json {
  {
      "review": "Fun Time 2",
      "rating": 4
  }
}

tests {
  const data = res.body;
  
  bru.setEnvVar("jwt", data.token);
}

settings {
  encodeUrl: true
  timeout: 0
}
